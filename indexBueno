<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>OCR Imagen</title>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@4/dist/tesseract.min.js"></script>

</head>
<body>

<h2>OCR Imagen</h2>

<input type="file" id="imagen" accept="image/*"><br><br>
<button onclick="analizar()">Analizar</button>

<pre id="resultado"></pre>

<script>
async function analizar(){
    const salida = document.getElementById("resultado");
    const file = document.getElementById("imagen").files[0];

    if(!file){
        salida.textContent = "Seleccione una imagen";
        return;
    }

    salida.textContent = "Inicializando OCR...\n";

    try {
        const worker = await Tesseract.createWorker({
            logger: m => {
                if(m.status === "recognizing text"){
                    salida.textContent = "Progreso OCR: " + Math.round(m.progress*100) + "%";
                }
            }
        });

        await worker.loadLanguage('eng');
        await worker.initialize('eng');

        salida.textContent += "\nOCR listo\n";
        salida.textContent += "Analizando: " + file.name + "\n";

        const { data } = await worker.recognize(file);

        salida.textContent += "\nRESULTADO:\n" + data.text + "\n";

        await worker.terminate();

        salida.textContent += "\nProceso terminado";
    } catch (e){
        salida.textContent = "Error: " + e.message;
        console.error(e);
    }
}
</script>

</body>
</html>
